{
  "name": "side-tree",
  "displayName": "%sideTree.displayName%",
  "description": "%sideTree.description%",
  "version": "0.1.7",
  "publisher": "boukichi",
  "engines": {
    "vscode": "^1.100.0"
  },
  "license": "MIT",
  "icon": "images/icon.png",
  "homepage": "https://github.com/BouKiCHi/vscode-side-tree",
  "repository": {
    "type": "git",
    "url": "https://github.com/BouKiCHi/vscode-side-tree.git"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "keybindings": [
      {
        "command": "sideTreeView.renameItem",
        "key": "F2",
        "when": "focusedView == sideTreeView || focusedView == sideTreeViewInExplorer"
      },
      {
        "command": "sideTreeView.moveItemUp",
        "key": "alt+up",
        "when": "focusedView == sideTreeView || focusedView == sideTreeViewInExplorer"
      },
      {
        "command": "sideTreeView.moveItemDown",
        "key": "alt+down",
        "when": "focusedView == sideTreeView || focusedView == sideTreeViewInExplorer"
      },
      {
        "command": "sideTreeView.moveItemParent",
        "key": "alt+left",
        "when": "focusedView == sideTreeView || focusedView == sideTreeViewInExplorer"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "SideTreeContainer",
          "title": "%sideTree.viewsContainers.activitybar.title%",
          "icon": "media/tree-icon.svg"
        }
      ]
    },
    "views": {
      "SideTreeContainer": [
        {
          "id": "sideTreeView",
          "name": "%sideTree.views.sideTreeView.name%",
          "icon": "media/tree-icon.svg"
        }
      ],
      "explorer": [
        {
          "icon": "media/tree-icon.svg",
          "id": "sideTreeViewInExplorer",
          "name": "%sideTree.views.sideTreeViewInExplorer.name%"
        }
      ]
    },
    "commands": [
      {
        "command": "sideTreeView.itemClicked",
        "title": "%sideTree.command.itemClicked.title%"
      },
      {
        "command": "sideTreeView.findItem",
        "title": "%sideTree.command.findItem.title%",
        "category": "%sideTree.command.category%"
      },
      {
        "command": "sideTreeView.addFolder",
        "title": "%sideTree.command.addFolder.title%",
        "category": "%sideTree.command.category%",
        "icon": {
          "dark": "media/create_new_folder_dark.svg",
          "light": "media/create_new_folder.svg"
        }
      },
      {
        "command": "sideTreeView.addFolderInExplorer",
        "title": "%sideTree.command.addFolder.title%",
        "category": "%sideTree.command.category%",
        "icon": {
          "dark": "media/create_new_folder_dark.svg",
          "light": "media/create_new_folder.svg"
        }
      },
      {
        "command": "sideTreeView.reloadData",
        "title": "%sideTree.command.reloadData.title%",
        "category": "%sideTree.command.category%",
        "icon": {
          "dark": "media/refresh_dark.svg",
          "light": "media/refresh.svg"
        }
      },
      {
        "command": "sideTreeView.importData",
        "title": "%sideTree.command.importData.title%",
        "category": "%sideTree.command.category%",
        "icon": {
          "dark": "media/place_item_dark.svg",
          "light": "media/place_item.svg"
        }
      },
      {
        "command": "sideTreeView.removeItem",
        "category": "%sideTree.command.category%",
        "title": "%sideTree.command.removeItem.title%"
      },
      {
        "command": "sideTreeView.renameItem",
        "category": "%sideTree.command.category%",
        "title": "%sideTree.command.renameItem.title%"
      },
      {
        "command": "sideTreeView.copyPath",
        "category": "%sideTree.command.category%",
        "title": "%sideTree.command.copyPath.title%"
      },
      {
        "command": "sideTreeView.addItemFromTab",
        "category": "%sideTree.command.category%",
        "title": "%sideTree.command.addItemFromTab.title%"
      },
      {
        "command": "sideTreeView.addItemFromExplorer",
        "category": "%sideTree.command.category%",
        "title": "%sideTree.command.addItemFromExplorer.title%"
      },
      {
        "command": "sideTreeView.revealItem",
        "category": "%sideTree.command.category%",
        "title": "%sideTree.command.revealItem.title%"
      },
      {
        "command": "sideTreeView.addSymbolFromCurrentLine",
        "category": "%sideTree.command.category%",
        "title": "%sideTree.command.addSymbolFromCurrentLine.title%"
      },
      {
        "command": "sideTreeView.moveItemUp",
        "category": "%sideTree.command.category%",
        "title": "%sideTree.command.moveItemUp.title%"
      },
      {
        "command": "sideTreeView.moveItemDown",
        "category": "%sideTree.command.category%",
        "title": "%sideTree.command.moveItemDown.title%"
      },
      {
        "command": "sideTreeView.moveItemParent",
        "category": "%sideTree.command.category%",
        "title": "%sideTree.command.moveItemParent.title%"
      },
      {
        "command": "sideTreeView.sortItems",
        "category": "%sideTree.command.category%",
        "title": "%sideTree.command.sortItems.title%"
      },
      {
        "command": "sideTreeView.sortRootFolder",
        "category": "%sideTree.command.category%",
        "title": "%sideTree.command.sortRootFolder.title%"
      },
      {
        "command": "sideTreeView.foldAllItems",
        "category": "%sideTree.command.category%",
        "title": "%sideTree.command.foldAllItems.title%",
        "icon": {
          "dark": "media/collapse_all_dark.svg",
          "light": "media/collapse_all.svg"
        }
      },
      {
        "command": "sideTreeView.openBackupFolder",
        "category": "%sideTree.command.category%",
        "title": "%sideTree.command.openBackupFolder.title%"
      },
      {
        "command": "sideTreeView.saveAs",
        "category": "%sideTree.command.category%",
        "title": "%sideTree.command.saveAs.title%"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "sideTreeView.renameItem",
          "when": "view == sideTreeView || view == sideTreeViewInExplorer",
          "group": "1_modification@1"
        },
        {
          "command": "sideTreeView.removeItem",
          "when": "view == sideTreeView || view == sideTreeViewInExplorer",
          "group": "1_modification@2"
        },
        {
          "command": "sideTreeView.addFolder",
          "when": "view == sideTreeView",
          "group": "1_modification@3"
        },
        {
          "command": "sideTreeView.addFolderInExplorer",
          "when": "view == sideTreeViewInExplorer",
          "group": "1_modification@3"
        },
        {
          "command": "sideTreeView.sortItems",
          "when": "view == sideTreeView || view == sideTreeViewInExplorer",
          "group": "1_modification@4"
        },
        {
          "command": "sideTreeView.importData",
          "when": "view == sideTreeView || view == sideTreeViewInExplorer",
          "group": "1_modification@5"
        },
        {
          "command": "sideTreeView.copyPath",
          "when": "view == sideTreeView || view == sideTreeViewInExplorer",
          "group": "6_copypath@1"
        },
        {
          "command": "sideTreeView.moveItemParent",
          "when": "view == sideTreeView || view == sideTreeViewInExplorer",
          "group": "2_move_modification@1"
        },
        {
          "command": "sideTreeView.moveItemUp",
          "when": "view == sideTreeView || view == sideTreeViewInExplorer",
          "group": "2_move_modification@2"
        },
        {
          "command": "sideTreeView.moveItemDown",
          "when": "view == sideTreeView || view == sideTreeViewInExplorer",
          "group": "2_move_modification@3"
        }
      ],
      "view/title": [
        {
          "command": "sideTreeView.addFolder",
          "when": "view == sideTreeView",
          "group": "navigation@1"
        },
        {
          "command": "sideTreeView.addFolderInExplorer",
          "when": "view == sideTreeViewInExplorer",
          "group": "navigation@1"
        },
        {
          "command": "sideTreeView.reloadData",
          "when": "view == sideTreeView || view == sideTreeViewInExplorer",
          "group": "navigation@2"
        },
        {
          "command": "sideTreeView.foldAllItems",
          "when": "view == sideTreeView || view == sideTreeViewInExplorer",
          "group": "navigation@3"
        },
        {
          "command": "sideTreeView.sortRootFolder",
          "when": "view == sideTreeView || view == sideTreeViewInExplorer",
          "group": "other@1"
        },
        {
          "command": "sideTreeView.openBackupFolder",
          "when": "view == sideTreeView || view == sideTreeViewInExplorer",
          "group": "other@2"
        },
        {
          "command": "sideTreeView.saveAs",
          "when": "view == sideTreeView || view == sideTreeViewInExplorer",
          "group": "other@3"
        }
      ],
      "editor/title/context": [
        {
          "command": "sideTreeView.addItemFromTab",
          "when": "resourceScheme == file",
          "group": "1_modification"
        },
        {
          "command": "sideTreeView.addSymbolFromCurrentLine",
          "when": "resourceScheme == file",
          "group": "1_modification"
        },
        {
          "command": "sideTreeView.revealItem",
          "when": "resourceScheme == file",
          "group": "1_modification"
        }
      ],
      "editor/context": [
        {
          "command": "sideTreeView.addSymbolFromCurrentLine",
          "when": "resourceScheme == file",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "sideTreeView.addItemFromExplorer",
          "when": "resourceScheme == file",
          "group": "1_modification"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "vscode-nls": "^5.2.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.100.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.0.1",
    "typescript": "^5.8.3"
  }
}
